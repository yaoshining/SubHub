APP_URL=https://subhub.example.com

# 当前部署唯一应使用的数据库 URL（pooled / runtime）
DATABASE_URL=postgresql://username:password@host:5432/subhub

# 当前部署唯一应使用的数据库 URL（direct / unpooled，用于 migration / DDL / bootstrap）
DATABASE_URL_UNPOOLED=postgresql://username:password@host:5432/subhub

# 本地 development 专用 dev 数据库真源
DEV_DATABASE_URL=postgresql://username:password@host:5432/subhub_dev
DEV_DATABASE_URL_UNPOOLED=postgresql://username:password@host:5432/subhub_dev

# 仅用于上线前 greenfield 首次管理员初始化；已有管理员或导入后必须关闭
# ALLOW_INITIAL_ADMIN_BOOTSTRAP=false
# INITIAL_ADMIN_IDENTIFIER=owner@example.com
# INITIAL_ADMIN_DISPLAY_NAME=Owner
# INITIAL_ADMIN_PASSWORD=replace-with-strong-password

# 可选：若未配置则使用默认 OpenSubtitles API 地址
OPENSUBTITLES_API_URL=https://api.opensubtitles.com/api/v3

# 生产环境必填，且长度至少 32 字符
PROVIDER_CREDENTIAL_ENCRYPTION_KEY=replace-with-32-char-min-encryption-key
ADMIN_SESSION_SECRET=replace-with-32-char-min-session-secret
CALLER_KEY_SECRET=replace-with-32-char-min-caller-key-secret
